{
  "name": "server",
  "version": "1.0.0",
  "description": "Amazon-style e-commerce — Express + PostgreSQL + React",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node index.js",
    "db:init": "node -e \"require('./database/setup').initSchema().then(()=>process.exit(0)).catch(e=>{console.error(e);process.exit(1)})\"",
    "db:seed": "node -e \"require('./database/seed').seed().then(()=>process.exit(0)).catch(e=>{console.error(e);process.exit(1)})\"",
    "heroku-postbuild": "cd client && npm install && npm run build"
  },
  "keywords": [
    "postgresql",
    "express",
    "react",
    "ecommerce"
  ],
  "author": "Ankit Kumar",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.14.0",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.0.1",
    "express": "^4.17.3",
    "express-validator": "^6.14.0",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^8.5.1",
    "moment": "^2.29.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.4",
    "nodemailer": "^6.9.8",
    "pg": "^8.11.3",
    "razorpay": "^2.8.1",
    "validator": "^13.7.0"
  }
}
