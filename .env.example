# PostgreSQL — use DATABASE_URL or individual vars
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/amazon_clone
# Or:
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=amazon_clone

# JWT & cookies
SECRET_KEY=change-this-to-a-long-random-string
COOKIE_SECRET=

# Default cart / checkout user when not logged in (must exist after seed; first user is id 1)
DEFAULT_USER_ID=1

# CORS — comma-separated origins
CLIENT_ORIGINS=http://localhost:3000

# Razorpay — key id + secret; pay-order verifies HMAC signature server-side before recording order
RAZORPAY_KEY_ID=
RAZORPAY_SECRET=

# Optional email (order confirmation) — Nodemailer SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

PORT=8000
